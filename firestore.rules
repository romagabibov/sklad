rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }
    
    function hasRole(role) {
      let userData = getUserData();
      return userData != null && userData.get('role', '') == role;
    }

    function isSuperAdmin() {
      return (request.auth != null && request.auth.token.email == 'vnsbek@gmail.com') || hasRole('superadmin');
    }

    function isAdmin() {
      let userData = getUserData();
      return isSuperAdmin() || (userData != null && (userData.get('role', '') == 'admin' || userData.get('role', '') == 'superadmin'));
    }

    function isApproved() {
      let userData = getUserData();
      return isSuperAdmin() || (userData != null && userData.get('status', '') == 'approved');
    }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 2
          && data.keys().hasAll(['email', 'createdAt'])
          && data.email is string && data.email.size() <= 256
          && data.createdAt is int
          && (!('name' in data) || (data.name is string && data.name.size() <= 256))
          && (!('role' in data) || (data.role in ['user', 'admin', 'superadmin']))
          && (!('status' in data) || (data.status in ['pending', 'approved', 'rejected']))
          && (!('password' in data) || data.password is string);
      }

      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) && isValidUser(incoming())
                    && (!('role' in incoming()) || incoming().role == 'user' || request.auth.token.email == 'vnsbek@gmail.com')
                    && (!('status' in incoming()) || incoming().status == 'pending' || request.auth.token.email == 'vnsbek@gmail.com');
                    
      allow update: if isValidUser(incoming()) && incoming().createdAt == existing().createdAt && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name'])) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'role'])) ||
        isSuperAdmin()
      );
    }
      
    // Shared Collections for the App
    match /products/{productId} {
      function isValidProduct(data) {
        return data.size() >= 5 && data.size() <= 10
          && data.keys().hasAll(['userId', 'name', 'price', 'stock', 'createdAt'])
          && data.name is string && data.name.size() <= 256 && data.name.size() > 0
          && data.price is number && data.price >= 0
          && data.stock is number && data.stock >= 0
          && data.createdAt is int
          && (!('sku' in data) || (data.sku is string && data.sku.size() <= 128))
          && (!('category' in data) || (data.category is string && data.category.size() <= 128))
          && (!('costPrice' in data) || (data.costPrice is number && data.costPrice >= 0))
          && (!('variants' in data) || (data.variants is list))
          && (!('updatedAt' in data) || data.updatedAt is int);
      }

      allow read: if isApproved();
      allow create: if isApproved() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isApproved() && isValidId(productId) 
                    && isValidProduct(incoming()) 
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasAny(['name', 'sku', 'category', 'price', 'costPrice', 'stock', 'variants', 'updatedAt']);
      allow delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }
    
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.size() >= 6 && data.size() <= 10
          && data.keys().hasAll(['userId', 'type', 'items', 'totalAmount', 'date', 'createdAt'])
          && data.type in ['IN', 'OUT', 'DISPATCH']
          && data.items is list && data.items.size() <= 100
          && data.items.size() > 0 
          && data.totalAmount is number && data.totalAmount >= 0
          && data.date is string && data.date.size() <= 32
          && data.createdAt is int
          && (!('documentNumber' in data) || (data.documentNumber is string && data.documentNumber.size() <= 128))
          && (!('recipientName' in data) || data.recipientName == null || (data.recipientName is string && data.recipientName.size() <= 256))
          && (!('isWholesale' in data) || data.isWholesale is bool)
          && (!('updatedAt' in data) || data.updatedAt is int);
      }

      allow read: if isApproved();
      allow create: if isApproved() && isValidId(transactionId) && isValidTransaction(incoming());
      allow delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }

    match /workers/{workerId} {
      function isValidWorker(data) {
        return data.size() >= 4 && data.size() <= 5
          && data.keys().hasAll(['userId', 'name', 'role', 'createdAt'])
          && data.name is string && data.name.size() <= 256 && data.name.size() > 0
          && data.role is string && data.role.size() <= 128
          && data.createdAt is int
          && (!('updatedAt' in data) || data.updatedAt is int);
      }

      allow read: if isApproved();
      allow create: if isApproved() && isValidId(workerId) && isValidWorker(incoming());
      allow update: if isApproved() && isValidId(workerId) 
                    && isValidWorker(incoming()) 
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasAny(['name', 'role', 'updatedAt']);
      allow delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }

    match /attendance/{attendanceId} {
      function isValidAttendance(data) {
        return data.size() >= 5 && data.size() <= 6
          && data.keys().hasAll(['userId', 'date', 'workerId', 'isPresent', 'createdAt'])
          && data.date is string && data.date.size() <= 32
          && data.workerId is string && data.workerId.size() <= 128
          && data.isPresent is bool
          && data.createdAt is int
          && (!('updatedAt' in data) || data.updatedAt is int);
      }

      allow read: if isApproved();
      allow create: if isApproved() && isValidId(attendanceId)  && isValidAttendance(incoming());
      allow update: if isApproved() && isValidId(attendanceId) 
                    && isValidAttendance(incoming()) 
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasAny(['isPresent', 'updatedAt']);
      allow delete: if isAdmin() || (isApproved() && existing().userId == request.auth.uid);
    }
  }
}
