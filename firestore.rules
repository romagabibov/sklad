rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.size() >= 2 && data.size() <= 3
          && data.keys().hasAll(['email', 'createdAt'])
          && data.email is string && data.email.size() <= 256
          && data.createdAt is int
          && (!('name' in data) || (data.name is string && data.name.size() <= 256));
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == existing().createdAt;
      
      // Subcollections
      match /products/{productId} {
        function isValidProduct(data) {
          return data.size() >= 5 && data.size() <= 9
            && data.keys().hasAll(['userId', 'name', 'price', 'stock', 'createdAt'])
            && data.userId == userId
            && data.name is string && data.name.size() <= 256 && data.name.size() > 0
            && data.price is number && data.price >= 0
            && data.stock is number && data.stock >= 0
            && data.createdAt is int
            && (!('sku' in data) || (data.sku is string && data.sku.size() <= 128))
            && (!('category' in data) || (data.category is string && data.category.size() <= 128))
            && (!('costPrice' in data) || (data.costPrice is number && data.costPrice >= 0))
            && (!('updatedAt' in data) || data.updatedAt is int);
        }

        allow read: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(productId) 
                      && isValidProduct(incoming());
        allow update: if isOwner(userId) && isValidId(productId) 
                      && isValidProduct(incoming()) 
                      && incoming().userId == existing().userId
                      && incoming().createdAt == existing().createdAt
                      && incoming().diff(existing()).affectedKeys().hasAny(['name', 'sku', 'category', 'price', 'costPrice', 'stock', 'updatedAt']);
        allow delete: if isOwner(userId) && existing().userId == request.auth.uid;
      }
      
      match /transactions/{transactionId} {
        function isValidTransaction(data) {
          return data.size() >= 6 && data.size() <= 10
            && data.keys().hasAll(['userId', 'type', 'items', 'totalAmount', 'date', 'createdAt'])
            && data.userId == userId
            && data.type in ['IN', 'OUT', 'DISPATCH']
            && data.items is list && data.items.size() <= 100
            && data.items.size() > 0 
            && data.totalAmount is number && data.totalAmount >= 0
            && data.date is string && data.date.size() <= 32
            && data.createdAt is int
            && (!('documentNumber' in data) || (data.documentNumber is string && data.documentNumber.size() <= 128))
            && (!('recipientName' in data) || data.recipientName == null || (data.recipientName is string && data.recipientName.size() <= 256))
            && (!('isWholesale' in data) || data.isWholesale is bool)
            && (!('updatedAt' in data) || data.updatedAt is int);
        }

        allow read: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(transactionId) 
                      && isValidTransaction(incoming());
        allow delete: if isOwner(userId) && existing().userId == request.auth.uid;
      }

      match /workers/{workerId} {
        function isValidWorker(data) {
          return data.size() >= 4 && data.size() <= 5
            && data.keys().hasAll(['userId', 'name', 'role', 'createdAt'])
            && data.userId == userId
            && data.name is string && data.name.size() <= 256 && data.name.size() > 0
            && data.role is string && data.role.size() <= 128
            && data.createdAt is int
            && (!('updatedAt' in data) || data.updatedAt is int);
        }

        allow read: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(workerId) 
                      && isValidWorker(incoming());
        allow update: if isOwner(userId) && isValidId(workerId) 
                      && isValidWorker(incoming()) 
                      && incoming().userId == existing().userId
                      && incoming().createdAt == existing().createdAt
                      && incoming().diff(existing()).affectedKeys().hasAny(['name', 'role', 'updatedAt']);
        allow delete: if isOwner(userId) && existing().userId == request.auth.uid;
      }

      match /attendance/{attendanceId} {
        function isValidAttendance(data) {
          return data.size() >= 5 && data.size() <= 6
            && data.keys().hasAll(['userId', 'date', 'workerId', 'isPresent', 'createdAt'])
            && data.userId == userId
            && data.date is string && data.date.size() <= 32
            && data.workerId is string && data.workerId.size() <= 128
            && data.isPresent is bool
            && data.createdAt is int
            && (!('updatedAt' in data) || data.updatedAt is int);
        }

        allow read: if isOwner(userId) && resource.data.userId == request.auth.uid;
        allow create: if isOwner(userId) && isValidId(attendanceId) 
                      && isValidAttendance(incoming());
        allow update: if isOwner(userId) && isValidId(attendanceId) 
                      && isValidAttendance(incoming()) 
                      && incoming().userId == existing().userId
                      && incoming().createdAt == existing().createdAt
                      && incoming().diff(existing()).affectedKeys().hasAny(['isPresent', 'updatedAt']);
        allow delete: if isOwner(userId) && existing().userId == request.auth.uid;
      }
    }
  }
}
